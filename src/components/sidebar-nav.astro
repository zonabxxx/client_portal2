---
// ============================================
// Portal Sidebar Navigation
// ============================================

import CartBadge from '@/components/cart-badge.tsx';

interface Props {
  activeNav?: string;
  clientName?: string;
}

const { activeNav = 'dashboard', clientName = 'Klient' } = Astro.props;

const navItems = [
  { id: 'dashboard', href: '/dashboard', label: 'Prehľad', icon: 'home' },
  { id: 'orders', href: '/orders', label: 'Zákazky', icon: 'package' },
  { id: 'quotes', href: '/quotes', label: 'Cenové ponuky', icon: 'file-text' },
  { id: 'invoices', href: '/invoices', label: 'Faktúry', icon: 'receipt' },
  { id: 'files', href: '/files', label: 'Súbory', icon: 'folder' },
  { id: 'products', href: '/products', label: 'Produkty', icon: 'shopping-bag' },
];
---

<nav class="portal-sidebar">
  <!-- Logo -->
  <a href="/dashboard" class="block mb-6">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded bg-adsun-orange flex items-center justify-center">
        <span class="text-adsun-black font-bold text-sm">AD</span>
      </div>
      <div>
        <span class="text-white font-semibold text-sm">AD Sun</span>
        <span class="block text-adsun-orange text-[10px] font-medium tracking-wide">KLIENTSKÝ PORTÁL</span>
      </div>
    </div>
  </a>

  <hr class="divider-orange mb-4 opacity-40" />

  <!-- Nav Items -->
  <div class="flex flex-col gap-1 flex-1">
    {navItems.map(item => (
      <a
        href={item.href}
        class={`nav-item ${activeNav === item.id ? 'active' : ''}`}
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          {item.icon === 'home' && <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />}
          {item.icon === 'package' && <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />}
          {item.icon === 'file-text' && <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />}
          {item.icon === 'receipt' && <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />}
          {item.icon === 'folder' && <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />}
          {item.icon === 'shopping-bag' && <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />}
        </svg>
        <span>{item.label}</span>
      </a>
    ))}

    <!-- Cart with live badge -->
    <CartBadge client:load />
  </div>

  <!-- User info -->
  <div class="mt-auto pt-4 border-t border-white/5">
    <div class="flex items-center gap-3 px-3 py-2">
      <div class="w-8 h-8 rounded-full bg-adsun-gray-light flex items-center justify-center">
        <span class="text-adsun-muted text-xs font-medium">{clientName.charAt(0).toUpperCase()}</span>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-white text-sm font-medium truncate">{clientName}</p>
      </div>
    </div>
    <a href="/api/auth/logout" class="nav-item text-adsun-muted mt-1">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" />
      </svg>
      <span>Odhlásiť sa</span>
    </a>
  </div>
</nav>
