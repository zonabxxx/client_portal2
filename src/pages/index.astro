---
// ============================================
// Login Page - Password + Magic Link + Google OAuth
// ============================================

import AuthLayout from '@/layouts/auth-layout.astro';
import { getSession } from '@/lib/auth';

const session = await getSession(Astro.request.headers.get('cookie'));
if (session) {
  return Astro.redirect('/dashboard');
}

const error = Astro.url.searchParams.get('error');
const sent = Astro.url.searchParams.get('sent');
const tab = Astro.url.searchParams.get('tab') || 'password';
---

<AuthLayout title="Prihlásenie">
  <div class="glass-card p-8 md:p-12 max-w-md w-full mx-4 text-center animate-in">
    <!-- Logo -->
    <div class="flex items-center justify-center gap-3 mb-8">
      <div class="w-12 h-12 rounded-lg bg-adsun-orange flex items-center justify-center">
        <span class="text-adsun-black font-bold text-xl">AD</span>
      </div>
      <div class="text-left">
        <span class="text-white font-bold text-lg block">AD Sun</span>
        <span class="text-adsun-orange text-xs font-medium tracking-widest">KLIENTSKY PORTAL</span>
      </div>
    </div>

    <h1 class="text-2xl font-bold text-white mb-2">Vitajte</h1>
    <p class="text-adsun-muted text-sm mb-6">
      Prihláste sa pre prístup k vašim zákazkám, ponukám a faktúram.
    </p>

    {error && (
      <div class="bg-red-500/10 border border-red-500/30 rounded-md p-3 mb-6 text-red-400 text-sm">
        {error === 'not_found' && 'Tento e-mail nie je registrovaný ako klient.'}
        {error === 'auth_failed' && 'Prihlásenie zlyhalo. Skúste to znova.'}
        {error === 'no_code' && 'Chýba autorizačný kód od Google.'}
        {error === 'link_expired' && 'Prihlasovací odkaz vypršal. Vyžiadajte si nový.'}
        {error === 'no_token' && 'Neplatný prihlasovací odkaz.'}
        {error !== 'not_found' && error !== 'auth_failed' && error !== 'no_code' && error !== 'link_expired' && error !== 'no_token' && 'Nastala chyba pri prihlásení.'}
      </div>
    )}

    {sent && (
      <div class="bg-green-500/10 border border-green-500/30 rounded-md p-3 mb-6 text-green-400 text-sm">
        Prihlasovací odkaz bol odoslaný na váš e-mail. Skontrolujte si poštu.
      </div>
    )}

    <!-- Tab switcher -->
    <div class="flex mb-6 rounded-lg bg-white/5 p-1" id="tab-switcher">
      <button
        data-tab="password"
        class="tab-btn flex-1 py-2 px-3 rounded-md text-sm font-medium transition-colors"
      >
        E-mail a heslo
      </button>
      <button
        data-tab="magic-link"
        class="tab-btn flex-1 py-2 px-3 rounded-md text-sm font-medium transition-colors"
      >
        Prihlasovací odkaz
      </button>
    </div>

    <!-- Error message container -->
    <div id="login-error" class="bg-red-500/10 border border-red-500/30 rounded-md p-3 mb-4 text-red-400 text-sm hidden"></div>

    <!-- Password Login Form -->
    <form id="password-form" class="mb-6">
      <div class="mb-3">
        <input
          type="email"
          id="password-email"
          name="email"
          placeholder="Zadajte váš firemný e-mail"
          required
          autocomplete="email"
          class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-adsun-muted
                 focus:border-adsun-orange focus:outline-none focus:ring-1 focus:ring-adsun-orange/50 transition-colors"
        />
      </div>
      <div class="mb-4">
        <input
          type="password"
          id="password-input"
          name="password"
          placeholder="Heslo"
          required
          minlength="6"
          autocomplete="current-password"
          class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-adsun-muted
                 focus:border-adsun-orange focus:outline-none focus:ring-1 focus:ring-adsun-orange/50 transition-colors"
        />
      </div>
      <button
        type="submit"
        id="password-btn"
        class="btn-primary w-full flex items-center justify-center gap-2 text-base"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="18" height="11" x="3" y="11" rx="2" ry="2" />
          <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
        Prihlásiť sa
      </button>
      <p class="text-xs text-adsun-muted mt-3">
        Nemáte ešte heslo? Použite <button type="button" class="text-adsun-orange hover:underline switch-to-magic">prihlasovací odkaz</button> a heslo si nastavíte po prihlásení.
      </p>
    </form>

    <!-- Magic Link Form -->
    <form id="magic-link-form" class="mb-6 hidden">
      <div class="mb-4">
        <input
          type="email"
          id="email-input"
          name="email"
          placeholder="Zadajte váš firemný e-mail"
          required
          autocomplete="email"
          class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-adsun-muted
                 focus:border-adsun-orange focus:outline-none focus:ring-1 focus:ring-adsun-orange/50 transition-colors"
        />
      </div>
      <button
        type="submit"
        id="magic-link-btn"
        class="btn-primary w-full flex items-center justify-center gap-2 text-base"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="20" height="16" x="2" y="4" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
        Poslať prihlasovací odkaz
      </button>
      <p class="text-xs text-adsun-muted mt-3">
        Pošleme vám jednorazový odkaz na e-mail. Žiadne heslo nie je potrebné.
      </p>
    </form>

    <!-- Divider -->
    <div class="flex items-center gap-3 mb-6">
      <div class="flex-1 h-px bg-white/10"></div>
      <span class="text-adsun-muted text-xs">alebo</span>
      <div class="flex-1 h-px bg-white/10"></div>
    </div>

    <!-- Google Login Button -->
    <a
      href="/api/auth/google"
      class="w-full flex items-center justify-center gap-3 text-base px-6 py-3 rounded-lg
             bg-white/5 border border-white/10 text-white hover:bg-white/10 transition-colors"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Prihlásiť sa cez Google
    </a>
  </div>

  <script define:vars={{ initialTab: tab }}>
    const passwordForm = document.getElementById('password-form');
    const magicLinkForm = document.getElementById('magic-link-form');
    const tabBtns = document.querySelectorAll('.tab-btn');
    const loginError = document.getElementById('login-error');
    const switchToMagicBtn = document.querySelector('.switch-to-magic');

    function showError(msg) {
      loginError.textContent = msg;
      loginError.classList.remove('hidden');
    }
    function hideError() {
      loginError.classList.add('hidden');
    }

    function switchTab(tab) {
      hideError();
      tabBtns.forEach(b => {
        if (b.dataset.tab === tab) {
          b.classList.add('bg-adsun-orange', 'text-adsun-black');
          b.classList.remove('text-adsun-muted');
        } else {
          b.classList.remove('bg-adsun-orange', 'text-adsun-black');
          b.classList.add('text-adsun-muted');
        }
      });
      if (tab === 'password') {
        passwordForm.classList.remove('hidden');
        magicLinkForm.classList.add('hidden');
      } else {
        passwordForm.classList.add('hidden');
        magicLinkForm.classList.remove('hidden');
      }
    }

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => switchTab(btn.dataset.tab));
    });

    if (switchToMagicBtn) {
      switchToMagicBtn.addEventListener('click', () => switchTab('magic-link'));
    }

    switchTab(initialTab);

    // Password login
    passwordForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideError();
      const email = document.getElementById('password-email').value.trim();
      const password = document.getElementById('password-input').value;
      if (!email || !password) return;

      const btn = document.getElementById('password-btn');
      btn.disabled = true;
      const origHTML = btn.innerHTML;
      btn.innerHTML = `
        <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        Prihlasujem...
      `;

      try {
        const res = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password }),
        });
        const data = await res.json();

        if (res.ok && data.success) {
          window.location.href = '/dashboard';
        } else {
          showError(data.error || 'Prihlásenie zlyhalo.');
          if (data.code === 'NO_PASSWORD') {
            setTimeout(() => switchTab('magic-link'), 2000);
          }
          btn.disabled = false;
          btn.innerHTML = origHTML;
        }
      } catch {
        showError('Nastala chyba pri pripojení.');
        btn.disabled = false;
        btn.innerHTML = origHTML;
      }
    });

    // Magic link
    const mlForm = document.getElementById('magic-link-form');
    const mlBtn = document.getElementById('magic-link-btn');
    const mlEmail = document.getElementById('email-input');

    mlForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideError();
      const email = mlEmail.value.trim();
      if (!email) return;

      mlBtn.disabled = true;
      const origHTML = mlBtn.innerHTML;
      mlBtn.innerHTML = `
        <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        Odosielam...
      `;

      try {
        const res = await fetch('/api/auth/magic-link/request', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await res.json();

        if (res.ok && data.directLink) {
          window.location.href = data.directLink;
        } else if (res.ok) {
          window.location.href = '/?sent=1';
        } else {
          showError(data.error || 'Nastala chyba.');
          mlBtn.disabled = false;
          mlBtn.innerHTML = origHTML;
        }
      } catch {
        showError('Nastala chyba pri pripojení.');
        mlBtn.disabled = false;
        mlBtn.innerHTML = origHTML;
      }
    });
  </script>
</AuthLayout>
