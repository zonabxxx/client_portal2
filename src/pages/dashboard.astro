---
// ============================================
// Dashboard - Prehľad pre klienta
// ============================================

import PortalLayout from '@/layouts/portal-layout.astro';
import RecentOrdersTable from '@/components/recent-orders-table';
import { getSession } from '@/lib/auth';
import { dashboardApi } from '@/lib/api-client';
import { formatCurrency } from '@/lib/utils';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/');

const dashRes = await dashboardApi.getStats(session.token);
const stats = dashRes.data?.stats || { activeOrders: 0, totalOrders: 0, unpaidInvoices: 0, unpaidAmount: 0, totalInvoiced: 0 };
const recentOrders = dashRes.data?.recentOrders || [];

// Dynamic greeting based on time of day
const hour = new Date().getHours();
const greeting = hour < 12 ? 'Dobré ráno' : hour < 18 ? 'Dobrý deň' : 'Dobrý večer';

// Display name: contact person name > shortened company name
function shortenCompanyName(name: string): string {
  return name
    .replace(/,?\s*s\.?\s*r\.?\s*o\.?\s*$/i, '')
    .replace(/,?\s*spol\.\s*s\s*r\.?\s*o\.?\s*$/i, '')
    .replace(/,?\s*a\.?\s*s\.?\s*$/i, '')
    .replace(/,?\s*s\.?\s*e\.?\s*$/i, '')
    .trim();
}
const displayName = session.contactName || shortenCompanyName(session.clientName);
const companyName = session.clientName;
---

<PortalLayout title="Prehľad" activeNav="dashboard">
  <!-- Welcome Header -->
  <header class="mb-8 animate-fade-up">
    <h1 class="text-xl md:text-2xl font-bold text-white">{greeting}, {displayName}</h1>
    <p class="text-adsun-muted text-sm mt-1">
      {companyName} — Váš prehľad zákaziek a financií
    </p>
  </header>

  <!-- Stats Grid -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="glass-card p-5 animate-fade-up delay-1">
      <div class="flex items-center justify-between mb-3">
        <p class="text-adsun-muted text-xs font-medium uppercase tracking-wide">Aktívne zákazky</p>
        <div class="w-8 h-8 rounded-lg bg-adsun-orange/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-adsun-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
        </div>
      </div>
      <p class="stat-number stat-orange">{stats.activeOrders}</p>
    </div>
    <div class="glass-card p-5 animate-fade-up delay-2">
      <div class="flex items-center justify-between mb-3">
        <p class="text-adsun-muted text-xs font-medium uppercase tracking-wide">Celkom zákaziek</p>
        <div class="w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
          </svg>
        </div>
      </div>
      <p class="stat-number stat-blue">{stats.totalOrders}</p>
    </div>
    <div class="glass-card p-5 animate-fade-up delay-3">
      <div class="flex items-center justify-between mb-3">
        <p class="text-adsun-muted text-xs font-medium uppercase tracking-wide">Nezaplatené faktúry</p>
        <div class="w-8 h-8 rounded-lg bg-red-500/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
          </svg>
        </div>
      </div>
      <p class="stat-number stat-red">{stats.unpaidInvoices}</p>
      <p class="text-adsun-muted text-xs mt-1">{formatCurrency(stats.unpaidAmount)}</p>
    </div>
    <div class="glass-card p-5 animate-fade-up delay-4">
      <div class="flex items-center justify-between mb-3">
        <p class="text-adsun-muted text-xs font-medium uppercase tracking-wide">Celkom fakturované</p>
        <div class="w-8 h-8 rounded-lg bg-green-500/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>
      <p class="stat-number stat-green">{formatCurrency(stats.totalInvoiced)}</p>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <a href="/products" class="glass-card p-5 flex items-center gap-4 group cursor-pointer animate-fade-up delay-3">
      <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-adsun-orange/20 to-adsun-orange/5 flex items-center justify-center group-hover:from-adsun-orange/30 group-hover:to-adsun-orange/10 transition-all duration-300">
        <svg class="w-6 h-6 text-adsun-orange transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
      </div>
      <div>
        <p class="text-white font-medium text-sm group-hover:text-adsun-orange transition-colors">Nová objednávka</p>
        <p class="text-adsun-muted text-xs">Objednať produkt z katalógu</p>
      </div>
      <svg class="w-5 h-5 text-adsun-muted ml-auto opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
      </svg>
    </a>

    <a href="/ai-search" class="glass-card p-5 flex items-center gap-4 group cursor-pointer animate-fade-up delay-4">
      <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-adsun-orange/20 to-adsun-orange/5 flex items-center justify-center group-hover:from-adsun-orange/30 group-hover:to-adsun-orange/10 transition-all duration-300">
        <svg class="w-6 h-6 text-adsun-orange transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
        </svg>
      </div>
      <div>
        <p class="text-white font-medium text-sm group-hover:text-adsun-orange transition-colors">AI Vyhľadávanie</p>
        <p class="text-adsun-muted text-xs">Nájsť alebo zopakovať zákazku</p>
      </div>
      <svg class="w-5 h-5 text-adsun-muted ml-auto opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
      </svg>
    </a>

    <a href="/orders" class="glass-card p-5 flex items-center gap-4 group cursor-pointer animate-fade-up delay-5">
      <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-adsun-orange/20 to-adsun-orange/5 flex items-center justify-center group-hover:from-adsun-orange/30 group-hover:to-adsun-orange/10 transition-all duration-300">
        <svg class="w-6 h-6 text-adsun-orange transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
        </svg>
      </div>
      <div>
        <p class="text-white font-medium text-sm group-hover:text-adsun-orange transition-colors">Moje zákazky</p>
        <p class="text-adsun-muted text-xs">Prehľad všetkých zákaziek</p>
      </div>
      <svg class="w-5 h-5 text-adsun-muted ml-auto opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
      </svg>
    </a>
  </div>

  <!-- Recent Orders -->
  <div class="glass-card overflow-hidden animate-fade-up delay-5">
    <div class="flex items-center justify-between p-5 border-b border-white/5">
      <h2 class="text-white font-semibold flex items-center gap-2">
        <svg class="w-5 h-5 text-adsun-orange" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Posledné zákazky
      </h2>
      <a href="/orders" class="text-adsun-orange text-sm font-medium hover:underline flex items-center gap-1 group">
        Zobraziť všetky
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </a>
    </div>

    <RecentOrdersTable client:load orders={recentOrders} />
  </div>
</PortalLayout>
