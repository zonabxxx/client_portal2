---
// ============================================
// Order Detail — bez cien, s horizontálnym progress barom
// ============================================

import PortalLayout from '@/layouts/portal-layout.astro';
import PortalHeader from '@/components/portal-header.astro';
import { getSession } from '@/lib/auth';
import { ordersApi } from '@/lib/api-client';
import { formatDate, getStatusBadge, translateStatus } from '@/lib/utils';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/');

const { id } = Astro.params;
const orderRes = await ordersApi.getById(id!, session.token);

if (!orderRes.success || !orderRes.data) {
  return Astro.redirect('/orders');
}

const order = orderRes.data;
const tasks = order.tasks || [];
const reorderProducts = order.reorderProducts || [];

const taskStatusMap: Record<string, { color: string; label: string; sort: number }> = {
  completed: { color: 'bg-green-400', label: 'Dokončené', sort: 0 },
  finished: { color: 'bg-green-400', label: 'Dokončené', sort: 0 },
  in_progress: { color: 'bg-adsun-orange', label: 'Prebieha', sort: 1 },
  pending: { color: 'bg-adsun-orange', label: 'Čaká', sort: 2 },
  blocked: { color: 'bg-red-400', label: 'Blokované', sort: 3 },
};

function getTaskInfo(status: string) {
  return taskStatusMap[status] || { color: 'bg-gray-500', label: status, sort: 4 };
}

const sortedTasks = [...tasks].sort((a: any, b: any) => {
  return (getTaskInfo(a.status).sort) - (getTaskInfo(b.status).sort);
});

const completedCount = tasks.filter((t: any) => t.status === 'completed' || t.status === 'finished').length;
const inProgressCount = tasks.filter((t: any) => t.status === 'in_progress' || t.status === 'pending').length;
const blockedCount = tasks.filter((t: any) => t.status === 'blocked').length;
const totalTasks = tasks.length;
const progressPct = totalTasks > 0 ? Math.round((completedCount / totalTasks) * 100) : 0;
---

<PortalLayout title={order.name} activeNav="orders">
  <div class="flex items-center gap-2 text-sm text-adsun-muted mb-4">
    <a href="/orders" class="hover:text-adsun-orange transition-colors">Zákazky</a>
    <span>›</span>
    <span class="text-white">{order.orderNumber}</span>
  </div>

  <PortalHeader title={order.name} subtitle={`Zákazka ${order.orderNumber}`}>
    <span class={`badge ${getStatusBadge(order.status)}`}>
      {translateStatus(order.status)}
    </span>
  </PortalHeader>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">

      {/* Description */}
      {order.description && (
        <div class="glass-card p-5 animate-in" style="animation-delay: 0s; opacity: 0;">
          <h3 class="text-white font-semibold mb-2">Popis</h3>
          <p class="text-adsun-muted text-sm leading-relaxed">{order.description}</p>
        </div>
      )}

      {/* Progress overview */}
      {totalTasks > 0 && (
        <div class="glass-card p-5 space-y-4 animate-in" style="animation-delay: 0.05s; opacity: 0;">
          <div class="flex items-center justify-between">
            <h3 class="text-white font-semibold">Priebeh zákazky</h3>
            <span class="text-adsun-orange font-bold text-lg">{progressPct}%</span>
          </div>

          {/* Main progress bar */}
          <div class="w-full h-3 bg-white/5 rounded-full overflow-hidden flex">
            {completedCount > 0 && (
              <div
                class="h-full bg-green-400 transition-all duration-500"
                style={`width: ${(completedCount / totalTasks) * 100}%`}
              />
            )}
            {inProgressCount > 0 && (
              <div
                class="h-full bg-adsun-orange transition-all duration-500"
                style={`width: ${(inProgressCount / totalTasks) * 100}%`}
              />
            )}
            {blockedCount > 0 && (
              <div
                class="h-full bg-red-400 transition-all duration-500"
                style={`width: ${(blockedCount / totalTasks) * 100}%`}
              />
            )}
          </div>

          {/* Legend */}
          <div class="flex flex-wrap gap-4 text-xs">
            {completedCount > 0 && (
              <div class="flex items-center gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-green-400"></span>
                <span class="text-adsun-muted">Dokončené ({completedCount})</span>
              </div>
            )}
            {inProgressCount > 0 && (
              <div class="flex items-center gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-adsun-orange"></span>
                <span class="text-adsun-muted">Prebieha ({inProgressCount})</span>
              </div>
            )}
            {blockedCount > 0 && (
              <div class="flex items-center gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
                <span class="text-adsun-muted">Blokované ({blockedCount})</span>
              </div>
            )}
          </div>
        </div>
      )}

      {/* Horizontal timeline of tasks */}
      {sortedTasks.length > 0 && (
        <div class="glass-card p-5 animate-in" style="animation-delay: 0.1s; opacity: 0;">
          <h3 class="text-white/60 text-xs uppercase tracking-widest font-semibold mb-4">Kroky zákazky</h3>

          <div class="relative">
            {/* Horizontal line */}
            <div class="absolute top-4 left-4 right-4 h-px bg-white/10"></div>

            <div class="flex overflow-x-auto gap-0 pb-2 task-timeline">
              {sortedTasks.map((t: any, idx: number) => {
                const info = getTaskInfo(t.status);
                const isFirst = idx === 0;
                const isLast = idx === sortedTasks.length - 1;
                return (
                  <div class={`flex-shrink-0 flex flex-col items-center text-center relative ${isFirst ? '' : ''}`} style={`min-width: ${Math.max(100 / sortedTasks.length, 14)}%; max-width: 200px;`}>
                    {/* Dot */}
                    <div class={`w-8 h-8 rounded-full ${info.color} flex items-center justify-center z-10 border-2 border-adsun-bg`}>
                      {(t.status === 'completed' || t.status === 'finished') ? (
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                      ) : (t.status === 'in_progress' || t.status === 'pending') ? (
                        <div class="w-2 h-2 rounded-full bg-white"></div>
                      ) : (
                        <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                      )}
                    </div>
                    {/* Label */}
                    <p class="text-white text-[11px] mt-2 leading-tight px-1 line-clamp-2">{t.taskName}</p>
                    <p class={`text-[10px] mt-0.5 ${t.status === 'completed' || t.status === 'finished' ? 'text-green-400' : t.status === 'blocked' ? 'text-red-400' : 'text-adsun-orange'}`}>
                      {info.label}
                    </p>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      )}

      {/* Empty state */}
      {totalTasks === 0 && (
        <div class="glass-card p-12 text-center text-adsun-muted animate-in" style="animation-delay: 0.05s; opacity: 0;">
          <p class="text-lg font-medium mb-1">Zákazka je v príprave</p>
          <p class="text-sm">Úlohy budú priradené po spracovaní zákazky.</p>
        </div>
      )}
    </div>

    {/* Sidebar */}
    <div class="space-y-4">
      <div class="glass-card p-5 space-y-4 animate-in" style="animation-delay: 0.05s; opacity: 0;">
        <h3 class="text-white font-semibold text-sm">Detaily</h3>

        <div>
          <p class="text-adsun-muted text-xs uppercase tracking-wide">Stav</p>
          <p class="mt-1">
            <span class={`badge ${getStatusBadge(order.status)}`}>
              {translateStatus(order.status)}
            </span>
          </p>
        </div>

        {order.priority && (
          <div>
            <p class="text-adsun-muted text-xs uppercase tracking-wide">Priorita</p>
            <p class="text-white text-sm mt-1 capitalize">{translateStatus(order.priority)}</p>
          </div>
        )}

        <div>
          <p class="text-adsun-muted text-xs uppercase tracking-wide">Vytvorená</p>
          <p class="text-white text-sm mt-1">{formatDate(order.createdAt)}</p>
        </div>

        {order.startDate && (
          <div>
            <p class="text-adsun-muted text-xs uppercase tracking-wide">Začiatok</p>
            <p class="text-white text-sm mt-1">{formatDate(order.startDate)}</p>
          </div>
        )}

        {order.plannedEndDate && (
          <div>
            <p class="text-adsun-muted text-xs uppercase tracking-wide">Deadline</p>
            <p class="text-white text-sm mt-1">{formatDate(order.plannedEndDate)}</p>
          </div>
        )}
      </div>

      {/* Reorder button */}
      {reorderProducts.length > 0 && (
        <div class="glass-card p-5 animate-in" style="animation-delay: 0.1s; opacity: 0;">
          <button
            id="btn-reorder"
            class="btn-primary w-full text-sm flex items-center justify-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644l3.182-3.182" />
            </svg>
            Objednať znova
          </button>
          <p class="text-adsun-muted text-[10px] mt-2 text-center">
            Pridá {reorderProducts.length} {reorderProducts.length === 1 ? 'produkt' : reorderProducts.length < 5 ? 'produkty' : 'produktov'} do košíka
          </p>
        </div>
      )}

      {/* NAS Files Link */}
      <a href={`/files?order=${id}`} class="glass-card p-5 flex items-center gap-3 group cursor-pointer block animate-in" style="animation-delay: 0.15s; opacity: 0;">
        <div class="w-9 h-9 rounded-lg bg-adsun-orange/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-adsun-orange" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
          </svg>
        </div>
        <div>
          <p class="text-white text-sm font-medium group-hover:text-adsun-orange transition-colors">Súbory zákazky</p>
          <p class="text-adsun-muted text-xs">Otvoriť na NAS</p>
        </div>
      </a>
    </div>
  </div>
</PortalLayout>

<style>
  .task-timeline {
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.1) transparent;
  }
  .task-timeline::-webkit-scrollbar {
    height: 4px;
  }
  .task-timeline::-webkit-scrollbar-track {
    background: transparent;
  }
  .task-timeline::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script is:inline define:vars={{ reorderProductsJson: JSON.stringify(reorderProducts) }}>
  document.getElementById('btn-reorder')?.addEventListener('click', () => {
    const CART_KEY = 'adsun_portal_cart';
    let cart = [];
    try { cart = JSON.parse(localStorage.getItem(CART_KEY) || '[]'); } catch { cart = []; }

    const products = JSON.parse(reorderProductsJson);
    for (const p of products) {
      cart.push({
        id: 'cart-' + Date.now() + '-' + Math.random().toString(36).slice(2, 8),
        productId: p.productId,
        productName: p.productName,
        productType: p.productType,
        variantId: p.variantId || null,
        variantName: p.variantName || null,
        quantity: p.quantity || 1,
        parameters: p.parameters || {},
        notes: '',
        fileNames: [],
        categoryId: p.categoryId || null,
        categoryName: p.categoryName || null,
        addedAt: new Date().toISOString(),
      });
    }
    localStorage.setItem(CART_KEY, JSON.stringify(cart));
    window.dispatchEvent(new CustomEvent('cart-updated', { detail: { count: cart.length } }));
    window.location.href = '/cart';
  });
</script>
