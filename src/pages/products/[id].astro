---
// ============================================
// Product Detail + Configurator
// Supports both: product templates (?type=template) and regular products (?type=product)
// ============================================

import PortalLayout from '@/layouts/portal-layout.astro';
import ProductConfigurator from '@/components/product-configurator';
import { getSession } from '@/lib/auth';
import { productsApi } from '@/lib/api-client';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/');

const { id } = Astro.params;
const url = new URL(Astro.request.url);
const productType = url.searchParams.get('type') || undefined;

const productRes = await productsApi.getById(id!, session.token, productType);

if (!productRes.success || !productRes.data) {
  return Astro.redirect('/products');
}

const product = productRes.data;
const categoryName = product.category || 'Katalóg';
const categoryId = product.categoryId;
---

<PortalLayout title={product.name} activeNav="products">
  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 text-sm text-adsun-muted mb-6">
    <a href="/products" class="hover:text-adsun-orange transition-colors">Produkty</a>
    <span>›</span>
    {categoryId ? (
      <a href={`/products?category=${categoryId}`} class="hover:text-adsun-orange transition-colors">{categoryName}</a>
    ) : (
      <span class="text-adsun-muted">{categoryName}</span>
    )}
    <span>›</span>
    <span class="text-white">{product.name}</span>
  </div>

  <div class="max-w-2xl">
    <ProductConfigurator client:load product={product} />
  </div>
</PortalLayout>
