---
// ============================================
// Files - NAS Browser
// ============================================

import PortalLayout from '@/layouts/portal-layout.astro';
import PortalHeader from '@/components/portal-header.astro';
import FileBrowser from '@/components/file-browser';
import { getSession } from '@/lib/auth';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/');

const orderPath = Astro.url.searchParams.get('order') || '';
---

<PortalLayout title="Súbory" activeNav="files">
  <PortalHeader title="Moje súbory" subtitle="Súbory vašich zákaziek na NAS" />

  <div class="glass-card p-5">
    <FileBrowser client:load initialPath={orderPath} />
  </div>
</PortalLayout>
