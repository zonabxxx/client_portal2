  },
  'de-AT': {
    quoteTitle: 'Angebot',
    error: 'Fehler',
    linkExpired: 'Dieser Link zum Angebot ist abgelaufen',
    loadError: 'Angebot konnte nicht geladen werden',
    connectionError: 'Verbindungsfehler',
    preparedQuote: 'wir haben ein Angebot für Sie vorbereitet',
    dearMrs: 'Sehr geehrte Frau',
    dearMr: 'Sehr geehrter Herr',
