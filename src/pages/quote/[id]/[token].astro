// ============================================
// Public Quote Page — /quote/[id]/[token]
// No auth required — accessed via share token
// Multi-language: SK, EN, DE-AT (?lang=)
// ============================================

import '@/styles/global.css';

const { id, token } = Astro.params;
const API_BASE = process.env.PUBLIC_API_URL || import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';

const langParam = Astro.url.searchParams.get('lang');
type Lang = 'sk' | 'en' | 'de-AT';
const lang: Lang = langParam === 'en' ? 'en' : langParam === 'de-AT' ? 'de-AT' : 'sk';
const htmlLang = lang === 'de-AT' ? 'de' : lang;
const needsTranslation = lang !== 'sk';

// Google Translate batch helper
const GOOGLE_API_KEY = process.env.GOOGLE_TRANSLATE_API_KEY || import.meta.env.GOOGLE_TRANSLATE_API_KEY || '';
const googleLang = lang === 'de-AT' ? 'de' : lang;
const _trCache = new Map<string, string>();

async function translateBatch(texts: string[]): Promise<string[]> {
  if (!needsTranslation || !GOOGLE_API_KEY) return texts;
  const filtered = texts.filter(Boolean);
  if (filtered.length === 0) return texts;

  const uncached: string[] = [];
  const uncachedIdx: number[] = [];
  const results = [...texts];

  texts.forEach((txt, i) => {
    if (!txt) return;
    if (_trCache.has(txt)) { results[i] = _trCache.get(txt)!; return; }
    uncached.push(txt);
    uncachedIdx.push(i);
  });

  if (uncached.length === 0) return results;

  try {
    const res = await fetch(`https://translation.googleapis.com/language/translate/v2?key=${GOOGLE_API_KEY}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ q: uncached, source: 'sk', target: googleLang, format: 'text' }),
    });
    if (res.ok) {
      const data = await res.json();
      const translations = data?.data?.translations || [];
      translations.forEach((tr: any, i: number) => {
        const translated = tr.translatedText || uncached[i];
        _trCache.set(uncached[i], translated);
        results[uncachedIdx[i]] = translated;
      });
    }
  } catch (e) {
    console.error('[TRANSLATE] batch error:', e);
  }
  return results;
}

async function tr(text: string): Promise<string> {
  if (!text || !needsTranslation) return text;
  const [result] = await translateBatch([text]);
  return result;
}

const T = {
  sk: {
    quoteTitle: 'Cenová ponuka',
    error: 'Chyba',
