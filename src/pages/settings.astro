---
// ============================================
// Settings - Account settings (password, etc.)
// ============================================

import PortalLayout from '@/layouts/portal-layout.astro';
import { getSession } from '@/lib/auth';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/');

function shortenCompanyName(name: string): string {
  return name
    .replace(/,?\s*s\.?\s*r\.?\s*o\.?\s*$/i, '')
    .replace(/,?\s*spol\.\s*s\s*r\.?\s*o\.?\s*$/i, '')
    .replace(/,?\s*a\.?\s*s\.?\s*$/i, '')
    .replace(/,?\s*s\.?\s*e\.?\s*$/i, '')
    .trim();
}
const displayName = session.contactName || shortenCompanyName(session.clientName);
---

<PortalLayout title="Nastavenia" activeNav="settings">
  <header class="mb-8 animate-fade-up">
    <h1 class="text-xl md:text-2xl font-bold text-white">Nastavenia</h1>
    <p class="text-adsun-muted text-sm mt-1">Správa vášho účtu</p>
  </header>

  <!-- Account Info -->
  <div class="glass-card p-6 mb-6 animate-fade-up delay-1">
    <h2 class="text-white font-semibold mb-4 flex items-center gap-2">
      <svg class="w-5 h-5 text-adsun-orange" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
      </svg>
      Informácie o účte
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <p class="text-adsun-muted text-xs uppercase tracking-wide mb-1">Meno</p>
        <p class="text-white text-sm">{displayName}</p>
      </div>
      <div>
        <p class="text-adsun-muted text-xs uppercase tracking-wide mb-1">Firma</p>
        <p class="text-white text-sm">{session.clientName}</p>
      </div>
      <div>
        <p class="text-adsun-muted text-xs uppercase tracking-wide mb-1">E-mail</p>
        <p class="text-white text-sm">{session.email}</p>
      </div>
    </div>
  </div>

  <!-- Notification Preferences -->
  <div class="glass-card p-6 mb-6 animate-fade-up delay-2">
    <h2 class="text-white font-semibold mb-4 flex items-center gap-2">
      <svg class="w-5 h-5 text-adsun-orange" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
      </svg>
      Emailové notifikácie
    </h2>
    <p class="text-adsun-muted text-sm mb-6">
      Nastavte si, o čom vás chceme informovať emailom.
    </p>

    <div id="notif-loading" class="text-adsun-muted text-sm">Načítavam nastavenia...</div>

    <div id="notif-settings" class="hidden space-y-4">
      <label class="flex items-center justify-between cursor-pointer group">
        <div>
          <p class="text-white text-sm font-medium group-hover:text-adsun-orange transition-colors">Potvrdenie objednávky</p>
          <p class="text-adsun-muted text-xs">Email po odoslaní novej objednávky</p>
        </div>
        <input type="checkbox" id="notif-orderConfirmation" class="notif-toggle sr-only peer" />
        <div class="relative w-11 h-6 bg-white/10 rounded-full peer peer-checked:bg-adsun-orange/80 after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full border border-white/10 peer-checked:border-adsun-orange/50"></div>
      </label>

      <label class="flex items-center justify-between cursor-pointer group">
        <div>
          <p class="text-white text-sm font-medium group-hover:text-adsun-orange transition-colors">Zmena stavu zákazky</p>
          <p class="text-adsun-muted text-xs">Email keď je zákazka potvrdená, v realizácii alebo dokončená</p>
        </div>
        <input type="checkbox" id="notif-orderStatusChange" class="notif-toggle sr-only peer" />
        <div class="relative w-11 h-6 bg-white/10 rounded-full peer peer-checked:bg-adsun-orange/80 after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full border border-white/10 peer-checked:border-adsun-orange/50"></div>
      </label>

      <label class="flex items-center justify-between cursor-pointer group">
        <div>
          <p class="text-white text-sm font-medium group-hover:text-adsun-orange transition-colors">Cenová ponuka pripravená</p>
          <p class="text-adsun-muted text-xs">Email keď je cenová ponuka pripravená na schválenie</p>
        </div>
        <input type="checkbox" id="notif-quoteReady" class="notif-toggle sr-only peer" />
        <div class="relative w-11 h-6 bg-white/10 rounded-full peer peer-checked:bg-adsun-orange/80 after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full border border-white/10 peer-checked:border-adsun-orange/50"></div>
      </label>

      <label class="flex items-center justify-between cursor-pointer group">
        <div>
          <p class="text-white text-sm font-medium group-hover:text-adsun-orange transition-colors">Nová faktúra</p>
          <p class="text-adsun-muted text-xs">Email pri vystavení novej faktúry</p>
        </div>
        <input type="checkbox" id="notif-invoiceIssued" class="notif-toggle sr-only peer" />
        <div class="relative w-11 h-6 bg-white/10 rounded-full peer peer-checked:bg-adsun-orange/80 after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full border border-white/10 peer-checked:border-adsun-orange/50"></div>
      </label>

      <div id="notif-status-msg" class="hidden rounded-md p-3 text-sm mt-4"></div>
    </div>
  </div>

  <!-- Google Account Link -->
  <div class="glass-card p-6 mb-6 animate-fade-up delay-3">
    <h2 class="text-white font-semibold mb-4 flex items-center gap-2">
      <svg class="w-5 h-5 text-adsun-orange" viewBox="0 0 24 24" fill="none">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Google účet
    </h2>
    <p class="text-adsun-muted text-sm mb-6">
      Prepojte svoj Google účet pre rýchle prihlásenie jedným klikom.
    </p>

    <div id="google-status" class="hidden rounded-md p-3 mb-4 text-sm"></div>

    <a
      href="/api/auth/google?link=true"
      id="link-google-btn"
      class="inline-flex items-center gap-3 px-6 py-3 rounded-lg bg-white/5 border border-white/10 text-white hover:bg-white/10 transition-colors"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Prepojiť Google účet
    </a>
  </div>

  <!-- Password Section -->
  <div class="glass-card p-6 animate-fade-up delay-4">
    <h2 class="text-white font-semibold mb-4 flex items-center gap-2">
      <svg class="w-5 h-5 text-adsun-orange" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
      </svg>
      Heslo pre prihlásenie
    </h2>
    <p class="text-adsun-muted text-sm mb-6">
      Nastavte si heslo, aby ste sa mohli prihlasovať pomocou e-mailu a hesla bez nutnosti použitia prihlasovacieho odkazu.
    </p>

    <!-- Status message -->
    <div id="password-status" class="hidden rounded-md p-3 mb-4 text-sm"></div>

    <form id="set-password-form" class="space-y-4 max-w-md">
      <div id="current-password-field" class="hidden">
        <label for="current-password" class="block text-adsun-muted text-xs uppercase tracking-wide mb-1">
          Aktuálne heslo
        </label>
        <input
          type="password"
          id="current-password"
          placeholder="Zadajte aktuálne heslo"
          class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-adsun-muted
                 focus:border-adsun-orange focus:outline-none focus:ring-1 focus:ring-adsun-orange/50 transition-colors"
        />
      </div>

      <div>
        <label for="new-password" class="block text-adsun-muted text-xs uppercase tracking-wide mb-1">
          Nové heslo
        </label>
        <input
          type="password"
          id="new-password"
          placeholder="Minimálne 6 znakov"
          required
          minlength="6"
          class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-adsun-muted
                 focus:border-adsun-orange focus:outline-none focus:ring-1 focus:ring-adsun-orange/50 transition-colors"
        />
      </div>

      <div>
        <label for="confirm-password" class="block text-adsun-muted text-xs uppercase tracking-wide mb-1">
          Zopakujte heslo
        </label>
        <input
          type="password"
          id="confirm-password"
          placeholder="Zopakujte nové heslo"
          required
          minlength="6"
          class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-adsun-muted
                 focus:border-adsun-orange focus:outline-none focus:ring-1 focus:ring-adsun-orange/50 transition-colors"
        />
      </div>

      <button
        type="submit"
        id="save-password-btn"
        class="btn-primary flex items-center justify-center gap-2 px-6 py-3"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Uložiť heslo
      </button>
    </form>
  </div>

  <script>
    // ── Google link status ──
    const googleStatus = document.getElementById('google-status')!;
    const urlParams = new URLSearchParams(window.location.search);
    const googleResult = urlParams.get('google');

    if (googleResult === 'linked') {
      const linkedEmail = urlParams.get('email') || '';
      googleStatus.textContent = `Google účet ${linkedEmail} bol úspešne prepojený! Teraz sa môžete prihlasovať cez Google.`;
      googleStatus.className = 'rounded-md p-3 mb-4 text-sm bg-green-500/10 border border-green-500/30 text-green-400';
      googleStatus.classList.remove('hidden');
      window.history.replaceState({}, '', '/settings');
    } else if (googleResult === 'error') {
      googleStatus.textContent = 'Prepojenie Google účtu zlyhalo. Skúste to znova.';
      googleStatus.className = 'rounded-md p-3 mb-4 text-sm bg-red-500/10 border border-red-500/30 text-red-400';
      googleStatus.classList.remove('hidden');
      window.history.replaceState({}, '', '/settings');
    }

    // ── Notification preferences ──
    const NOTIF_KEYS = ['orderConfirmation', 'orderStatusChange', 'quoteReady', 'invoiceIssued'];
    const notifLoading = document.getElementById('notif-loading')!;
    const notifSettings = document.getElementById('notif-settings')!;
    const notifStatusMsg = document.getElementById('notif-status-msg')!;
    let savingNotif = false;

    async function loadNotifPrefs() {
      try {
        const res = await fetch('/api/proxy/settings/notifications');
        if (!res.ok) throw new Error();
        const prefs = await res.json();

        for (const key of NOTIF_KEYS) {
          const el = document.getElementById(`notif-${key}`) as HTMLInputElement;
          if (el) el.checked = prefs[key] !== false;
        }

        notifLoading.classList.add('hidden');
        notifSettings.classList.remove('hidden');
      } catch {
        notifLoading.textContent = 'Nepodarilo sa načítať nastavenia.';
      }
    }

    async function saveNotifPrefs() {
      if (savingNotif) return;
      savingNotif = true;

      const prefs: Record<string, boolean> = {};
      for (const key of NOTIF_KEYS) {
        const el = document.getElementById(`notif-${key}`) as HTMLInputElement;
        prefs[key] = el?.checked ?? true;
      }

      try {
        const res = await fetch('/api/proxy/settings/notifications', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(prefs),
        });

        if (res.ok) {
          notifStatusMsg.textContent = 'Nastavenia uložené.';
          notifStatusMsg.className = 'rounded-md p-3 text-sm mt-4 bg-green-500/10 border border-green-500/30 text-green-400';
          notifStatusMsg.classList.remove('hidden');
          setTimeout(() => notifStatusMsg.classList.add('hidden'), 2500);
        }
      } catch { /* silent */ }
      savingNotif = false;
    }

    loadNotifPrefs();

    document.querySelectorAll('.notif-toggle').forEach(toggle => {
      toggle.addEventListener('change', saveNotifPrefs);
    });

    // ── Password form ──
    const form = document.getElementById('set-password-form') as HTMLFormElement;
    const statusEl = document.getElementById('password-status')!;
    const currentPasswordField = document.getElementById('current-password-field')!;

    function showStatus(msg: string, type: 'success' | 'error') {
      statusEl.textContent = msg;
      statusEl.className = `rounded-md p-3 mb-4 text-sm ${
        type === 'success'
          ? 'bg-green-500/10 border border-green-500/30 text-green-400'
          : 'bg-red-500/10 border border-red-500/30 text-red-400'
      }`;
      statusEl.classList.remove('hidden');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      statusEl.classList.add('hidden');

      const newPassword = (document.getElementById('new-password') as HTMLInputElement).value;
      const confirmPassword = (document.getElementById('confirm-password') as HTMLInputElement).value;
      const currentPassword = (document.getElementById('current-password') as HTMLInputElement).value;

      if (newPassword !== confirmPassword) {
        showStatus('Heslá sa nezhodujú.', 'error');
        return;
      }

      if (newPassword.length < 6) {
        showStatus('Heslo musí mať aspoň 6 znakov.', 'error');
        return;
      }

      const btn = document.getElementById('save-password-btn') as HTMLButtonElement;
      btn.disabled = true;
      const origHTML = btn.innerHTML;
      btn.innerHTML = `
        <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        Ukladám...
      `;

      try {
        const body: Record<string, string> = { password: newPassword };
        if (currentPassword) body.currentPassword = currentPassword;

        const res = await fetch('/api/auth/set-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        const data = await res.json();

        if (res.ok && data.success) {
          showStatus('Heslo bolo úspešne nastavené. Teraz sa môžete prihlasovať e-mailom a heslom.', 'success');
          form.reset();
          currentPasswordField.classList.remove('hidden');
        } else if (res.status === 400 && data.error?.includes('aktuálne heslo')) {
          currentPasswordField.classList.remove('hidden');
          showStatus(data.error, 'error');
        } else {
          showStatus(data.error || 'Nastavenie hesla zlyhalo.', 'error');
        }
      } catch {
        showStatus('Nastala chyba pri pripojení.', 'error');
      }

      btn.disabled = false;
      btn.innerHTML = origHTML;
    });
  </script>
</PortalLayout>
