      },
      {
        id: 'calc-006',
        name: 'Samolepky na produkty',
        calculationNumber: 'CC-2026-0092',
        totalPrice: 2491.00,
        approvalStatus: 'SENT',
        createdAt: '2026-02-21T10:00:00Z',
      },
    ],
  },
  {
    id: 'proj-002',
    name: 'Polep dodávok – Trans Logistics',
    projectNumber: 'PP-2026-0038',
    totalPrice: 6720.00,
    createdAt: '2026-01-20T09:00:00Z',
    calculations: [
      {
        id: 'calc-010',
        name: 'Celopolep Sprinter (3 vozidlá)',
        calculationNumber: 'CC-2026-0070',
        totalPrice: 4320.00,
        approvalStatus: 'CLIENT_APPROVED',
