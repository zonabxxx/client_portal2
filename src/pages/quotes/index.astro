---
// ============================================
// Quotes List - Cenové ponuky zoskupené podľa projektov
// ============================================

import PortalLayout from '@/layouts/portal-layout.astro';
import PortalHeader from '@/components/portal-header.astro';
import { getSession } from '@/lib/auth';
import { quotesApi } from '@/lib/api-client';
import { formatCurrency, formatDate, getStatusBadge, translateStatus } from '@/lib/utils';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/');

const quotesRes = await quotesApi.getAll(session.token);
const data = quotesRes.data || { projects: [], totalProjects: 0, totalCalculations: 0 };
const projects = data.projects || [];
const totalCalcs = data.totalCalculations || 0;

// Count pending calcs
let pendingCount = 0;
for (const p of projects) {
  for (const c of p.calculations || []) {
    if (c.status === 'SENT' || c.approvalStatus === 'SENT') pendingCount++;
  }
}
---

<PortalLayout title="Cenové ponuky" activeNav="quotes">
  <PortalHeader
    title="Cenové ponuky"
    subtitle={`${projects.length} projektov • ${totalCalcs} kalkulácií • ${pendingCount} čaká na odpoveď`}
  />

  {projects.length === 0 ? (
    <div class="glass-card p-12 text-center text-adsun-muted">
      <svg class="w-12 h-12 mx-auto mb-4 opacity-30" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
      </svg>
      <p class="text-lg font-medium mb-1">Žiadne cenové ponuky</p>
      <p class="text-sm">Vaše cenové ponuky sa tu zobrazia po vytvorení.</p>
    </div>
  ) : (
    <div class="space-y-4">
      {projects.map((project: any) => (
        <div class="glass-card overflow-hidden" data-project>
          {/* Project header */}
          <button
            class="w-full flex items-center justify-between p-5 text-left hover:bg-white/5 transition-colors"
            data-toggle-project
          >
            <div class="flex items-center gap-4 min-w-0">
              <div class="w-10 h-10 rounded-lg bg-adsun-orange/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-adsun-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
                </svg>
              </div>
              <div class="min-w-0">
                <h3 class="text-white font-medium truncate">{project.name}</h3>
                <div class="flex items-center gap-3 text-xs text-adsun-muted mt-0.5">
                  <span class="font-mono text-adsun-orange/70">{project.projectNumber}</span>
                  <span>•</span>
                  <span>{(project.calculations || []).length} kalkulácií</span>
                  <span>•</span>
                  <span>{formatDate(project.createdAt)}</span>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-4 flex-shrink-0">
              <span class="text-adsun-orange font-semibold text-lg hidden sm:block">
                {formatCurrency(project.totalPrice)}
              </span>
              <svg class="w-5 h-5 text-adsun-muted transition-transform duration-200" data-chevron fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </div>
          </button>

          {/* Calculations list (hidden by default) */}
          <div class="hidden border-t border-adsun-border" data-calcs-panel>
            {(project.calculations || []).length === 0 ? (
              <div class="p-6 text-center text-adsun-muted text-sm">
                Žiadne kalkulácie v tomto projekte
              </div>
            ) : (
              <div class="divide-y divide-adsun-border/50">
                {(project.calculations || []).map((calc: any) => (
                  <a href={`/quotes/${calc.id}`} class="px-5 py-4 flex items-center justify-between hover:bg-white/5 transition-colors cursor-pointer block" style="text-decoration:none;">
                    <div class="flex items-center gap-3 min-w-0">
                      <div class="w-2 h-2 rounded-full bg-adsun-orange/50 flex-shrink-0"></div>
                      <div class="min-w-0">
                        <p class="text-white text-sm font-medium truncate">{calc.name}</p>
                        <p class="text-adsun-muted text-xs mt-0.5 font-mono">
                          {calc.calculationNumber}
                        </p>
                      </div>
                    </div>
                    <div class="flex items-center gap-4 flex-shrink-0">
                      <span class={`badge ${getStatusBadge(calc.approvalStatus || calc.status)}`}>
                        {translateStatus(calc.approvalStatus || calc.status)}
                      </span>
                      <span class="text-adsun-orange font-medium text-sm min-w-[80px] text-right">
                        {formatCurrency(calc.totalPrice)}
                      </span>
                      <span class="text-adsun-muted text-xs hidden md:block min-w-[80px] text-right">
                        {formatDate(calc.createdAt)}
                      </span>
                      {(calc.approvalStatus === 'SENT' || calc.status === 'SENT') ? (
                        <div class="flex gap-2" onclick="event.preventDefault(); event.stopPropagation();">
                          <button
                            class="btn-primary btn-sm text-xs"
                            data-quote-id={calc.id}
                            data-action="approve"
                            onclick="handleQuoteAction(this)"
                          >
                            Schváliť
                          </button>
                          <button
                            class="btn-secondary btn-sm text-xs"
                            data-quote-id={calc.id}
                            data-action="reject"
                            onclick="handleQuoteAction(this)"
                          >
                            Zamietnuť
                          </button>
                        </div>
                      ) : (
                        <svg class="w-4 h-4 text-adsun-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                        </svg>
                      )}
                    </div>
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  )}
</PortalLayout>

<script is:inline>
  // Toggle project expand/collapse
  document.querySelectorAll('[data-toggle-project]').forEach(btn => {
    btn.addEventListener('click', () => {
      const project = btn.closest('[data-project]');
      const panel = project.querySelector('[data-calcs-panel]');
      const chevron = btn.querySelector('[data-chevron]');

      panel.classList.toggle('hidden');
      chevron.style.transform = panel.classList.contains('hidden') ? '' : 'rotate(180deg)';
    });
  });

  // Auto-expand first project
  const firstToggle = document.querySelector('[data-toggle-project]');
  if (firstToggle) firstToggle.click();

  // Quote approve/reject
  async function handleQuoteAction(btn) {
    const quoteId = btn.dataset.quoteId;
    const action = btn.dataset.action === 'approve' ? 'approved' : 'rejected';

    let comment = '';
    if (action === 'rejected') {
      comment = prompt('Dôvod zamietnutia (voliteľné):') || '';
      if (comment === null) return;
    }

    try {
      btn.disabled = true;
      btn.textContent = '...';

      const res = await fetch(`/api/proxy/quotes/${quoteId}/respond`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action, comment }),
      });

      if (res.ok) {
        window.location.reload();
      } else {
        alert('Chyba pri odpovedi na ponuku');
      }
    } catch {
      alert('Chyba pripojenia');
    } finally {
      btn.disabled = false;
    }
  }
</script>
