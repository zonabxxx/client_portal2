        calculationNumber: 'CC-2026-0071',
        totalPrice: 1200.00,
        approvalStatus: 'IN_PROGRESS',
        createdAt: '2026-01-22T14:00:00Z',
      },
      {
        id: 'calc-012',
        name: 'Magnetické tabuľky',
        calculationNumber: 'CC-2026-0072',
