      },
      {
        id: 'calc-002',
        name: 'Hlavičkové papiere A4',
        calculationNumber: 'CC-2026-0088',
        totalPrice: 380.00,
        approvalStatus: 'CLIENT_APPROVED',
        createdAt: '2026-02-15T11:15:00Z',
      },
      {
        id: 'calc-003',
        name: 'Firemná brožúra 16str',
        calculationNumber: 'CC-2026-0089',
        totalPrice: 1265.00,
        approvalStatus: 'SENT',
        createdAt: '2026-02-16T08:30:00Z',
      },
      {
        id: 'calc-004',
        name: 'Roll-up banner 85×200',
