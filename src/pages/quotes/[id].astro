  id: id,
  name: 'Kalkulácia',
  calculationNumber: 'CC-DEMO',
  approvalStatus: 'DRAFT',
  totalPrice: 0,
  createdAt: new Date().toISOString(),
  validUntil: null,
  notes: null,
  categoryName: null,
  project: null,
  products: [],
  communication: [],
};

const project = calc.project;
const products = calc.products || [];
const communication = calc.communication || [];

// Calculate unit prices
const enrichedProducts = products.map((p: any) => {
  const qty = p.quantity || 1;
  const unitPrice = qty > 0 ? p.totalSale / qty : 0;
  return { ...p, unitPrice };
});

const isPending = calc.approvalStatus === 'SENT';
const isApproved = calc.approvalStatus === 'CLIENT_APPROVED';
const isCompleted = calc.approvalStatus === 'COMPLETED';
