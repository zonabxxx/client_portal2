---
// ============================================
// Quote Detail — Shows calculation products, materials, services
// ============================================

import PortalLayout from '@/layouts/portal-layout.astro';
import PortalHeader from '@/components/portal-header.astro';
import { getSession } from '@/lib/auth';
import { quotesApi } from '@/lib/api-client';
import { formatCurrency, formatDate, getStatusBadge, translateStatus } from '@/lib/utils';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/');

const { id } = Astro.params;
const res = await quotesApi.getById(id!, session.token);

if (!res.success || !res.data) {
  return Astro.redirect('/quotes');
}

const calc = res.data;
const project = calc.project;
const products = calc.products || [];
const reorderProducts = calc.reorderProducts || [];

// Calculate unit prices for each product
const enrichedProducts = products.map((p: any) => {
  const qty = p.quantity || 1;
  const unitPrice = qty > 0 ? (p.totalSale || 0) / qty : 0;
  return { ...p, unitPrice };
});
---

<PortalLayout title={calc.name || 'Detail ponuky'} activeNav="quotes">
  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 text-sm text-adsun-muted mb-4">
    <a href="/quotes" class="hover:text-adsun-orange transition-colors">Cenové ponuky</a>
    <span>›</span>
    {project && (
      <>
        <span class="text-white/60">{project.name}</span>
        <span>›</span>
      </>
    )}
    <span class="text-white">{calc.calculationNumber}</span>
  </div>

  <PortalHeader title={calc.name || 'Kalkulácia'} subtitle={`${calc.calculationNumber}`}>
    <span class={`badge ${getStatusBadge(calc.approvalStatus)}`}>
      {translateStatus(calc.approvalStatus)}
    </span>
  </PortalHeader>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">

      {/* Products */}
      {enrichedProducts.length > 0 && (
        <div class="space-y-4">
          {enrichedProducts.map((product: any, idx: number) => (
            <div class="glass-card overflow-hidden animate-in" style={`animation-delay: ${idx * 0.05}s; opacity: 0;`}>
              {/* Product header */}
              <div class="p-5">
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0 flex-1">
                    <h3 class="text-white font-medium text-base">{product.name}</h3>

                    {/* Template config labels (variant info) */}
                    {product.templateConfigLabels && typeof product.templateConfigLabels === 'object' && Object.keys(product.templateConfigLabels).length > 0 && (
                      <div class="flex flex-wrap gap-1.5 mt-2">
                        {Object.entries(product.templateConfigLabels).map(([key, value]: [string, any]) => (
                          <span class="text-[11px] px-2 py-0.5 rounded bg-white/5 text-adsun-muted border border-white/5">
                            {typeof value === 'string' ? value : `${key}: ${value}`}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>

                {/* Price breakdown */}
                <div class="mt-4 pt-4 border-t border-white/5">
                  <div class="grid grid-cols-3 gap-4">
                    <div>
                      <p class="text-adsun-muted text-xs uppercase tracking-wide">Cena/{product.unit || 'ks'}</p>
                      <p class="text-white font-medium text-sm mt-1">{formatCurrency(product.unitPrice)}</p>
                    </div>
                    <div>
                      <p class="text-adsun-muted text-xs uppercase tracking-wide">Množstvo</p>
                      <p class="text-white font-medium text-sm mt-1">{product.quantity} {product.unit || 'ks'}</p>
                    </div>
                    <div class="text-right">
                      <p class="text-adsun-muted text-xs uppercase tracking-wide">Celkom</p>
                      <p class="text-adsun-orange font-semibold text-lg mt-1">{formatCurrency(product.totalSale)}</p>
                    </div>
                  </div>
                </div>

                {/* If no price yet */}
                {(!product.totalSale || product.totalSale === 0) && (
                  <div class="mt-3 text-center text-adsun-muted text-sm py-2 bg-white/[0.02] rounded">
                    Cena bude doplnená po spracovaní kalkulácie.
                  </div>
                )}

                {/* Expandable: product parts (materials + services) — names only, no prices */}
                {((product.materials && product.materials.length > 0) || (product.services && product.services.length > 0)) && (
                  <div class="mt-4">
                    <button
                      class="product-detail-toggle flex items-center gap-1.5 text-xs text-adsun-muted hover:text-adsun-orange transition-colors cursor-pointer"
                      data-target={`parts-${idx}`}
                    >
                      <svg class="toggle-icon w-3.5 h-3.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                      <span>Zobraziť súčiastky produktu</span>
                    </button>

                    <div id={`parts-${idx}`} class="product-parts hidden mt-3 pl-1 space-y-3">
                      {/* Materials list */}
                      {product.materials && product.materials.length > 0 && (
                        <div>
                          <p class="text-[10px] font-semibold text-adsun-muted uppercase tracking-widest mb-1.5">Materiály</p>
                          <div class="space-y-1">
                            {product.materials.map((m: any) => (
                              <div class="flex items-center gap-2 text-sm text-white/70">
                                <span class="w-1.5 h-1.5 rounded-full bg-adsun-orange/40 flex-shrink-0"></span>
                                <span>{m.name}</span>
                                <span class="text-adsun-muted text-xs">({m.quantity} {m.unit})</span>
                              </div>
                            ))}
                          </div>
                        </div>
                      )}

                      {/* Services list */}
                      {product.services && product.services.length > 0 && (
                        <div>
                          <p class="text-[10px] font-semibold text-adsun-muted uppercase tracking-widest mb-1.5">Služby</p>
                          <div class="space-y-1">
                            {product.services.map((s: any) => (
                              <div class="flex items-center gap-2 text-sm text-white/70">
                                <span class="w-1.5 h-1.5 rounded-full bg-blue-400/40 flex-shrink-0"></span>
                                <span>{s.name}</span>
                                <span class="text-adsun-muted text-xs">({s.quantity} {s.unit})</span>
                              </div>
                            ))}
                          </div>
                        </div>
                      )}
                    </div>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      )}

      {/* Notes */}
      {calc.notes && (
        <div class="glass-card p-5">
          <h3 class="text-white font-semibold mb-2">Poznámky</h3>
          <p class="text-adsun-muted text-sm leading-relaxed">{calc.notes}</p>
        </div>
      )}

      {/* Empty state */}
      {products.length === 0 && (
        <div class="glass-card p-12 text-center text-adsun-muted">
          <p class="text-lg font-medium mb-1">Žiadne produkty v kalkulácii</p>
          <p class="text-sm">Kalkulácia zatiaľ neobsahuje žiadne produkty.</p>
        </div>
      )}
    </div>

    <!-- Sidebar -->
    <div class="space-y-4">
      {/* Summary */}
      <div class="glass-card p-5 space-y-4">
        <h3 class="text-white font-semibold text-sm">Súhrn</h3>

        <div>
          <p class="text-adsun-muted text-xs uppercase tracking-wide">Celková cena</p>
          <p class="text-adsun-orange text-2xl font-bold mt-1">{formatCurrency(calc.totalPrice)}</p>
        </div>

        <div>
          <p class="text-adsun-muted text-xs uppercase tracking-wide">Stav</p>
          <p class="mt-1">
            <span class={`badge ${getStatusBadge(calc.approvalStatus)}`}>
              {translateStatus(calc.approvalStatus)}
            </span>
          </p>
        </div>

        <div>
          <p class="text-adsun-muted text-xs uppercase tracking-wide">Produkty</p>
          <p class="text-white text-sm mt-1">{enrichedProducts.length} {enrichedProducts.length === 1 ? 'produkt' : enrichedProducts.length < 5 ? 'produkty' : 'produktov'}</p>
        </div>

        <div>
          <p class="text-adsun-muted text-xs uppercase tracking-wide">Vytvorená</p>
          <p class="text-white text-sm mt-1">{formatDate(calc.createdAt)}</p>
        </div>

        {calc.categoryName && (
          <div>
            <p class="text-adsun-muted text-xs uppercase tracking-wide">Kategória</p>
            <p class="text-white text-sm mt-1">{calc.categoryName}</p>
          </div>
        )}
      </div>

      {/* Project info */}
      {project && (
        <div class="glass-card p-5 space-y-3">
          <h3 class="text-white font-semibold text-sm">Projekt</h3>
          <div>
            <p class="text-white text-sm">{project.name}</p>
            <p class="text-adsun-muted text-xs font-mono mt-0.5">{project.projectNumber}</p>
          </div>
          <div>
            <p class="text-adsun-muted text-xs">Celková hodnota projektu</p>
            <p class="text-adsun-orange font-semibold mt-0.5">{formatCurrency(project.totalPrice)}</p>
          </div>
        </div>
      )}

      {/* Reorder button */}
      {reorderProducts.length > 0 && (
        <div class="glass-card p-5">
          <button
            id="btn-reorder"
            class="btn-primary w-full text-sm flex items-center justify-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644l3.182-3.182" />
            </svg>
            Objednať znova
          </button>
          <p class="text-adsun-muted text-[10px] mt-2 text-center">
            Pridá {reorderProducts.length} {reorderProducts.length === 1 ? 'produkt' : reorderProducts.length < 5 ? 'produkty' : 'produktov'} do košíka
          </p>
        </div>
      )}

      {/* Actions — approve/reject if SENT */}
      {(calc.approvalStatus === 'SENT') && (
        <div class="glass-card p-5 space-y-3">
          <h3 class="text-white font-semibold text-sm">Akcie</h3>
          <button
            class="btn-primary w-full text-sm"
            id="btn-approve"
          >
            Schváliť ponuku
          </button>
          <button
            class="btn-secondary w-full text-sm"
            id="btn-reject"
          >
            Zamietnuť ponuku
          </button>
        </div>
      )}
    </div>
  </div>
</PortalLayout>

<script is:inline define:vars={{ calcId: id, reorderProductsJson: JSON.stringify(reorderProducts) }}>
  // ── Reorder: add products to cart ──
  document.getElementById('btn-reorder')?.addEventListener('click', () => {
    const CART_KEY = 'adsun_portal_cart';
    let cart = [];
    try { cart = JSON.parse(localStorage.getItem(CART_KEY) || '[]'); } catch { cart = []; }

    const products = JSON.parse(reorderProductsJson);
    for (const p of products) {
      cart.push({
        id: 'cart-' + Date.now() + '-' + Math.random().toString(36).slice(2, 8),
        productId: p.productId,
        productName: p.productName,
        productType: p.productType,
        variantId: p.variantId || null,
        variantName: p.variantName || null,
        quantity: p.quantity || 1,
        parameters: p.parameters || {},
        notes: '',
        fileNames: [],
        categoryId: p.categoryId || null,
        categoryName: p.categoryName || null,
        addedAt: new Date().toISOString(),
      });
    }
    localStorage.setItem(CART_KEY, JSON.stringify(cart));
    window.dispatchEvent(new CustomEvent('cart-updated', { detail: { count: cart.length } }));
    window.location.href = '/cart';
  });

  // Toggle product parts
  document.querySelectorAll('.product-detail-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const target = document.getElementById(targetId);
      const icon = btn.querySelector('.toggle-icon');
      if (!target) return;

      const isHidden = target.classList.contains('hidden');
      target.classList.toggle('hidden');
      if (icon) icon.style.transform = isHidden ? 'rotate(90deg)' : '';
      btn.querySelector('span:last-child').textContent = isHidden
        ? 'Skryť súčiastky produktu'
        : 'Zobraziť súčiastky produktu';
    });
  });

  // Approve/reject actions
  document.getElementById('btn-approve')?.addEventListener('click', async () => {
    if (!confirm('Naozaj chcete schváliť túto ponuku?')) return;
    try {
      const res = await fetch(`/api/proxy/quotes/${calcId}/respond`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'approved', comment: '' }),
      });
      if (res.ok) window.location.reload();
      else alert('Chyba pri schvaľovaní ponuky');
    } catch { alert('Chyba pripojenia'); }
  });

  document.getElementById('btn-reject')?.addEventListener('click', async () => {
    const comment = prompt('Dôvod zamietnutia (voliteľné):') || '';
    try {
      const res = await fetch(`/api/proxy/quotes/${calcId}/respond`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'rejected', comment }),
      });
      if (res.ok) window.location.reload();
      else alert('Chyba pri zamietnutí ponuky');
    } catch { alert('Chyba pripojenia'); }
  });
</script>
