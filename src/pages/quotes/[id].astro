<PortalLayout title={calc.name || 'Detail ponuky'} activeNav="quotes">
  {/* ── Breadcrumb ── */}
  <div class="flex items-center gap-2 text-sm text-adsun-muted mb-4">
    <a href="/quotes" class="hover:text-adsun-orange transition-colors">Cenové ponuky</a>
    <span class="text-white/20">›</span>
    {project && (
      <>
        <span class="text-white/60">{project.name}</span>
        <span class="text-white/20">›</span>
      </>
    )}
    <span class="text-white">{calc.calculationNumber}</span>
  </div>

  <PortalHeader title={calc.name || 'Kalkulácia'} subtitle={calc.calculationNumber}>
    <span class={`badge ${getStatusBadge(calc.approvalStatus)}`}>
      {translateStatus(calc.approvalStatus)}
    </span>
  </PortalHeader>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    {/* ════════════════════════════════════════
        HLAVNÝ OBSAH (2/3)
        ════════════════════════════════════════ */}
    <div class="lg:col-span-2 space-y-6">

      {/* ── Upozornenie ak čaká na schválenie ── */}
      {isPending && (
        <div class="glass-card p-5 border-adsun-orange/30 bg-adsun-orange/[0.04] animate-in" style="animation-delay: 0s; opacity: 0;">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-full bg-adsun-orange/15 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-adsun-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
              </svg>
            </div>
            <div>
              <h3 class="text-white font-semibold text-sm">Čaká na vaše schválenie</h3>
              <p class="text-adsun-muted text-sm mt-1">
                Táto ponuka bola pripravená a čaká na vašu odpoveď. Môžete ju schváliť, zamietnuť alebo požiadať o zmeny.
              </p>
              {calc.validUntil && (
                <p class="text-adsun-muted text-xs mt-2">
                  Platnosť ponuky do: <span class="text-white font-medium">{formatDate(calc.validUntil)}</span>
                </p>
              )}
            </div>
          </div>
        </div>
      )}

      {/* ── Produkty ── */}
      {enrichedProducts.length > 0 && (
        <div class="space-y-4">
          <h2 class="text-white/60 text-xs uppercase tracking-widest font-semibold">
            Produkty ({enrichedProducts.length})
          </h2>

          {enrichedProducts.map((product: any, idx: number) => (
            <div class="glass-card overflow-hidden animate-in" style={`animation-delay: ${(idx + 1) * 0.06}s; opacity: 0;`}>
              <div class="p-5">
                {/* Product header */}
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0 flex-1">
                    <h3 class="text-white font-medium text-base">{product.name}</h3>

                    {/* Config labels */}
                    {product.templateConfigLabels && Object.keys(product.templateConfigLabels).length > 0 && (
                      <div class="flex flex-wrap gap-1.5 mt-2">
                        {Object.entries(product.templateConfigLabels).map(([key, value]: [string, any]) => (
                          <span class="text-[11px] px-2 py-0.5 rounded-md bg-white/5 text-adsun-muted border border-white/5">
                            <span class="text-white/40">{key}:</span> {value}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>

                  {/* Product index */}
                  <div class="w-8 h-8 rounded-lg bg-adsun-orange/10 flex items-center justify-center flex-shrink-0">
                    <span class="text-adsun-orange text-xs font-bold">{idx + 1}</span>
                  </div>
                </div>

                {/* Price breakdown */}
                <div class="mt-4 pt-4 border-t border-white/5">
                  {product.totalSale && product.totalSale > 0 ? (
                    <div class="grid grid-cols-3 gap-4">
                      <div>
                        <p class="text-adsun-muted text-xs uppercase tracking-wide">Cena/{product.unit || 'ks'}</p>
                        <p class="text-white font-medium text-sm mt-1">{formatCurrency(product.unitPrice)}</p>
                      </div>
                      <div>
                        <p class="text-adsun-muted text-xs uppercase tracking-wide">Množstvo</p>
                        <p class="text-white font-medium text-sm mt-1">
                          {product.quantity?.toLocaleString('sk-SK')} {product.unit || 'ks'}
                        </p>
                      </div>
                      <div class="text-right">
                        <p class="text-adsun-muted text-xs uppercase tracking-wide">Celkom</p>
                        <p class="text-adsun-orange font-semibold text-lg mt-1">{formatCurrency(product.totalSale)}</p>
                      </div>
                    </div>
                  ) : (
                    <div class="text-center text-adsun-muted text-sm py-2 bg-white/[0.02] rounded-lg">
                      Cena bude doplnená po spracovaní kalkulácie.
                    </div>
                  )}
                </div>

                {/* Expandable parts */}
                {((product.materials?.length > 0) || (product.services?.length > 0)) && (
                  <div class="mt-4">
                    <button
                      class="product-detail-toggle flex items-center gap-1.5 text-xs text-adsun-muted hover:text-adsun-orange transition-colors cursor-pointer"
                      data-target={`parts-${idx}`}
                    >
                      <svg class="toggle-icon w-3.5 h-3.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                      <span class="toggle-label">Zobraziť zloženie produktu</span>
                    </button>

                    <div id={`parts-${idx}`} class="product-parts hidden mt-3 pl-1 space-y-3">
                      {/* Materials */}
                      {product.materials?.length > 0 && (
                        <div>
                          <p class="text-[10px] font-semibold text-adsun-muted uppercase tracking-widest mb-2 flex items-center gap-1.5">
                            <svg class="w-3 h-3 text-adsun-orange/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
                            </svg>
                            Materiály
                          </p>
                          <div class="space-y-1.5">
                            {product.materials.map((m: any) => (
                              <div class="flex items-center gap-2 text-sm text-white/70">
                                <span class="w-1.5 h-1.5 rounded-full bg-adsun-orange/40 flex-shrink-0"></span>
                                <span class="flex-1">{m.name}</span>
                                <span class="text-adsun-muted text-xs font-mono">{m.quantity} {m.unit}</span>
                              </div>
                            ))}
                          </div>
                        </div>
                      )}

                      {/* Services */}
                      {product.services?.length > 0 && (
                        <div>
                          <p class="text-[10px] font-semibold text-adsun-muted uppercase tracking-widest mb-2 flex items-center gap-1.5">
                            <svg class="w-3 h-3 text-blue-400/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.74-3.31a1 1 0 010-1.72l5.74-3.31a1 1 0 011.16 0l5.74 3.31a1 1 0 010 1.72l-5.74 3.31a1 1 0 01-1.16 0z" />
                            </svg>
                            Služby
                          </p>
                          <div class="space-y-1.5">
                            {product.services.map((s: any) => (
                              <div class="flex items-center gap-2 text-sm text-white/70">
                                <span class="w-1.5 h-1.5 rounded-full bg-blue-400/40 flex-shrink-0"></span>
                                <span class="flex-1">{s.name}</span>
                                <span class="text-adsun-muted text-xs font-mono">{s.quantity} {s.unit}</span>
                              </div>
                            ))}
                          </div>
                        </div>
                      )}
                    </div>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      )}

      {/* ── Poznámky ── */}
      {calc.notes && (
        <div class="glass-card p-5 animate-in" style={`animation-delay: ${(enrichedProducts.length + 1) * 0.06}s; opacity: 0;`}>
          <h3 class="text-white/60 text-xs uppercase tracking-widest font-semibold mb-3 flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-adsun-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
            </svg>
            Poznámky
          </h3>
          <p class="text-adsun-muted text-sm leading-relaxed">{calc.notes}</p>
        </div>
      )}

      {/* ── História komunikácie ── */}
      {communication.length > 0 && (
        <div class="glass-card p-5 animate-in" style={`animation-delay: ${(enrichedProducts.length + 2) * 0.06}s; opacity: 0;`}>
          <h3 class="text-white/60 text-xs uppercase tracking-widest font-semibold mb-4 flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-adsun-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
            </svg>
            História komunikácie
          </h3>

          <div class="relative">
            {/* Timeline line */}
            <div class="absolute left-[11px] top-3 bottom-3 w-px bg-white/10"></div>

            <div class="space-y-4">
              {communication.map((msg: any) => {
                const isSystem = msg.type === 'system';
                const isClient = msg.type === 'client';
                const isAdmin = msg.type === 'admin';

                return (
                  <div class="flex gap-3 relative">
                    {/* Dot */}
                    <div class:list={[
                      'w-[23px] h-[23px] rounded-full flex items-center justify-center flex-shrink-0 z-10',
                      isSystem ? 'bg-white/10' :
                      isClient ? 'bg-adsun-orange/20 border border-adsun-orange/30' :
                      'bg-blue-500/20 border border-blue-500/30',
                    ]}>
                      {isSystem ? (
                        <svg class="w-3 h-3 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                      ) : isClient ? (
                        <svg class="w-3 h-3 text-adsun-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                        </svg>
                      ) : (
                        <svg class="w-3 h-3 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0" />
                        </svg>
                      )}
                    </div>

                    {/* Content */}
                    <div class="flex-1 min-w-0 pb-1">
                      {isSystem ? (
                        <p class="text-adsun-muted text-xs italic">{msg.message}</p>
                      ) : (
                        <div class:list={[
                          'rounded-lg p-3',
                          isClient ? 'bg-adsun-orange/[0.06] border border-adsun-orange/10' :
                          'bg-white/[0.03] border border-white/5',
                        ]}>
                          <div class="flex items-center justify-between mb-1">
                            <span class:list={[
                              'text-xs font-semibold',
                              isClient ? 'text-adsun-orange' : 'text-blue-400'
                            ]}>
                              {msg.author}
                            </span>
                            <span class="text-adsun-muted text-[10px]">
                              {isClient ? 'Vy' : 'AD Sun'}
                            </span>
                          </div>
                          <p class="text-white/80 text-sm leading-relaxed">{msg.message}</p>
                        </div>
                      )}
                      <p class="text-adsun-muted text-[10px] mt-1 ml-1">{formatDate(msg.date)}</p>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          {/* Formulár na správu (ak čaká na schválenie) */}
          {isPending && (
            <div class="mt-6 pt-4 border-t border-white/5">
              <label class="text-white/60 text-xs uppercase tracking-widest font-semibold block mb-2">
                Vaša odpoveď
              </label>
              <textarea
                id="client-message"
                rows="3"
                class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white text-sm placeholder:text-white/20 focus:border-adsun-orange focus:ring-1 focus:ring-adsun-orange/30 transition-colors resize-none"
                placeholder="Napíšte správu alebo otázku..."
              ></textarea>
              <div class="flex gap-2 mt-3">
                <button
                  id="btn-send-message"
                  class="btn-secondary btn-sm text-xs flex items-center gap-1.5"
                >
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
                  </svg>
                  Odoslať otázku
                </button>
              </div>
            </div>
          )}
        </div>
      )}

      {/* Empty state */}
      {products.length === 0 && (
        <div class="glass-card p-12 text-center text-adsun-muted">
          <p class="text-lg font-medium mb-1">Žiadne produkty v kalkulácii</p>
          <p class="text-sm">Kalkulácia zatiaľ neobsahuje žiadne produkty.</p>
        </div>
      )}
    </div>

    {/* ════════════════════════════════════════
        SIDEBAR (1/3)
        ════════════════════════════════════════ */}
    <div class="space-y-4">
      {/* ── Súhrn ── */}
      <div class="glass-card p-5 space-y-4 animate-in" style="animation-delay: 0.05s; opacity: 0;">
        <h3 class="text-white/60 text-xs uppercase tracking-widest font-semibold">Súhrn</h3>

        <div>
          <p class="text-adsun-muted text-xs uppercase tracking-wide">Celková cena</p>
          <p class="text-adsun-orange text-2xl font-bold mt-1">{formatCurrency(calc.totalPrice)}</p>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <p class="text-adsun-muted text-xs uppercase tracking-wide">Stav</p>
            <p class="mt-1">
              <span class={`badge ${getStatusBadge(calc.approvalStatus)}`}>
                {translateStatus(calc.approvalStatus)}
              </span>
            </p>
          </div>
          <div>
            <p class="text-adsun-muted text-xs uppercase tracking-wide">Produkty</p>
            <p class="text-white text-sm mt-1 font-medium">
              {enrichedProducts.length} {enrichedProducts.length === 1 ? 'produkt' : enrichedProducts.length < 5 ? 'produkty' : 'produktov'}
            </p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <p class="text-adsun-muted text-xs uppercase tracking-wide">Vytvorená</p>
            <p class="text-white text-sm mt-1">{formatDate(calc.createdAt)}</p>
          </div>
          {calc.validUntil && (
            <div>
              <p class="text-adsun-muted text-xs uppercase tracking-wide">Platí do</p>
              <p class="text-white text-sm mt-1">{formatDate(calc.validUntil)}</p>
            </div>
          )}
        </div>

        {calc.categoryName && (
          <div>
            <p class="text-adsun-muted text-xs uppercase tracking-wide">Kategória</p>
            <p class="text-white text-sm mt-1">{calc.categoryName}</p>
          </div>
        )}
      </div>

      {/* ── Projekt ── */}
      {project && (
        <div class="glass-card p-5 space-y-3 animate-in" style="animation-delay: 0.1s; opacity: 0;">
          <h3 class="text-white/60 text-xs uppercase tracking-widest font-semibold">Projekt</h3>
          <div>
            <p class="text-white text-sm font-medium">{project.name}</p>
            <p class="text-adsun-muted text-xs font-mono mt-0.5">{project.projectNumber}</p>
          </div>
          <div>
            <p class="text-adsun-muted text-xs uppercase tracking-wide">Celková hodnota projektu</p>
            <p class="text-adsun-orange font-semibold mt-0.5">{formatCurrency(project.totalPrice)}</p>
          </div>
        </div>
      )}

      {/* ── Akcie — Schválenie / Zamietnutie ── */}
      {isPending && (
        <div class="glass-card p-5 space-y-3 animate-in" style="animation-delay: 0.15s; opacity: 0;">
          <h3 class="text-white/60 text-xs uppercase tracking-widest font-semibold">Akcie</h3>
          <button
            id="btn-approve"
            class="btn-primary w-full text-sm flex items-center justify-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            Schváliť ponuku
          </button>
          <button
            id="btn-reject"
            class="btn-secondary w-full text-sm flex items-center justify-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
            Zamietnuť ponuku
          </button>
          <button
            id="btn-request-changes"
            class="btn-secondary w-full text-sm flex items-center justify-center gap-2 border-yellow-500/30 text-yellow-400 hover:border-yellow-500 hover:text-yellow-300"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
            </svg>
            Požiadať o zmeny
          </button>
        </div>
      )}

      {/* ── Info ak schválená ── */}
      {isApproved && (
        <div class="glass-card p-5 space-y-3 animate-in border-green-500/20" style="animation-delay: 0.15s; opacity: 0;">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h3 class="text-green-400 font-semibold text-sm">Ponuka schválená</h3>
          </div>
          <p class="text-adsun-muted text-sm">
            Táto ponuka bola schválená. Zákazka je v procese spracovania.
          </p>
        </div>
      )}

      {/* ── Info ak dokončená ── */}
      {isCompleted && (
        <div class="glass-card p-5 space-y-3 animate-in border-green-500/20" style="animation-delay: 0.15s; opacity: 0;">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
            </svg>
            <h3 class="text-green-400 font-semibold text-sm">Zákazka dokončená</h3>
          </div>
          <p class="text-adsun-muted text-sm">
            Zákazka bola úspešne zrealizovaná a dokončená.
          </p>
          <button class="btn-primary w-full text-sm flex items-center justify-center gap-2" id="btn-reorder">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644l3.182-3.182" />
            </svg>
            Objednať znova
          </button>
        </div>
      )}

      {/* ── Cena po produktoch ── */}
      {enrichedProducts.length > 1 && (
        <div class="glass-card p-5 animate-in" style="animation-delay: 0.2s; opacity: 0;">
          <h3 class="text-white/60 text-xs uppercase tracking-widest font-semibold mb-3">Rozpad ceny</h3>
          <div class="space-y-2.5">
            {enrichedProducts.map((p: any) => (
              <div class="flex items-center justify-between text-sm">
                <span class="text-adsun-muted truncate mr-3">{p.name}</span>
                <span class="text-white font-medium flex-shrink-0">{formatCurrency(p.totalSale)}</span>
              </div>
            ))}
            <div class="border-t border-white/10 pt-2.5 flex items-center justify-between">
              <span class="text-white font-semibold text-sm">Spolu</span>
              <span class="text-adsun-orange font-bold text-base">{formatCurrency(calc.totalPrice)}</span>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</PortalLayout>

<script is:inline define:vars={{ calcId: id }}>
  // ── Toggle product parts ──
  document.querySelectorAll('.product-detail-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const target = document.getElementById(targetId);
      const icon = btn.querySelector('.toggle-icon');
      const label = btn.querySelector('.toggle-label');
      if (!target) return;

      const isHidden = target.classList.contains('hidden');
      target.classList.toggle('hidden');
      if (icon) icon.style.transform = isHidden ? 'rotate(90deg)' : '';
      if (label) label.textContent = isHidden
        ? 'Skryť zloženie produktu'
        : 'Zobraziť zloženie produktu';
    });
  });

  // ── DEMO: Approve ──
  document.getElementById('btn-approve')?.addEventListener('click', () => {
    if (!confirm('Naozaj chcete schváliť túto ponuku?')) return;
    alert('DEMO: Ponuka by bola schválená. (Zatiaľ nie je napojené na backend.)');
  });

  // ── DEMO: Reject ──
  document.getElementById('btn-reject')?.addEventListener('click', () => {
    const comment = prompt('Dôvod zamietnutia (voliteľné):');
    if (comment === null) return;
    alert('DEMO: Ponuka by bola zamietnutá. (Zatiaľ nie je napojené na backend.)');
  });

  // ── DEMO: Request changes ──
  document.getElementById('btn-request-changes')?.addEventListener('click', () => {
    const changes = prompt('Aké zmeny požadujete?');
    if (!changes) return;
    alert('DEMO: Požiadavka na zmeny by bola odoslaná. (Zatiaľ nie je napojené na backend.)');
  });

  // ── DEMO: Send message ──
  document.getElementById('btn-send-message')?.addEventListener('click', () => {
    const textarea = document.getElementById('client-message');
    const message = textarea?.value?.trim();
    if (!message) {
      alert('Prosím napíšte správu.');
      return;
    }
    alert('DEMO: Správa by bola odoslaná. (Zatiaľ nie je napojené na backend.)');
    textarea.value = '';
  });

  // ── DEMO: Reorder ──
  document.getElementById('btn-reorder')?.addEventListener('click', () => {
    alert('DEMO: Produkty by boli pridané do košíka. (Zatiaľ nie je napojené na backend.)');
  });
</script>
